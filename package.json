{
  "name": "world-dog-registry-docs",
  "version": "0.1.0",
  "private": true,
  "description": "World Dog Statistics Platform backend",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "import:fixture:jkc": "ts-node src/jobs/import-fixtures/import-registration-statistics-fixture.ts --source JKC --year 2024 --file fixtures/registration-statistics/jkc-2024.html",
    "import:fixture:rkc": "ts-node src/jobs/import-fixtures/import-registration-statistics-fixture.ts --source RKC --year 2024 --file fixtures/registration-statistics/rkc-2024.html",
    "import:jkc:retrievers:recent": "ts-node src/jobs/import-jkc-recent/import-jkc-retriever-registration-statistics.ts --limit 10",
    "import:rkc:retrievers:ten-year": "ts-node src/jobs/import-rkc-ten-year/import-rkc-retriever-registration-statistics.ts",
    "import:akc:retriever-rankings": "ts-node src/jobs/import-akc-rankings/import-akc-retriever-popularity-rankings.ts",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
